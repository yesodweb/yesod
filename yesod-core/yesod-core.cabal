                  , monad-logger
                  , deepseq
                  , blaze-html
                  , aeson
                  , primitive
                  , case-insensitive
                  , wai-logger
                  , memory
                  , unix-compat
                  , auto-update
                  , vector
                  , word8
                  , blaze-markup
                  , fast-logger
                  , parsec
