    build-depends:  base >= 4.11 && < 5
                  , async
                  , bytestring
                  , clientsession
                  , conduit
                  , conduit-extra
                  , containers
                  , cookie >= 0.4.1    && < 0.6
                  , data-default
                  , hspec >= 1.3
                  , hspec-expectations
                  , http-types
                  , network
                  , random
                  , resourcet
                  , shakespeare
                  , streaming-commons
                  , template-haskell
